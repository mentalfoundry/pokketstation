# Build directories
build/
build-*/
build_*/

# Local test assets (BIOS dumps, memory card images, etc.) - never commit
# copyrighted firmware or commercial save/game data.
/testdata/

# Diagnostic reports written by frontends/desktop/main.c during manual
# testing (see docs/hardware-notes.md) - local debugging artifacts, not
# something to commit.
psemu_report_*.log

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf
